# Capacitor 빌드 전용 환경변수
# 사용법: cp .env.capacitor .env.local && npm run build:capacitor

NEXT_PUBLIC_BUILD_TARGET=capacitor
NEXT_PUBLIC_SITE_URL=https://gotcha.it.com
NEXT_PUBLIC_API_BASE_URL=https://api.gotcha.it.com
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_key_here
NEXT_PUBLIC_KAKAO_OAUTH_CLIENT_ID=your_kakao_oauth_client_id
NEXT_PUBLIC_NAVER_OAUTH_CLIENT_ID=your_naver_oauth_client_id
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
